# This script helps me publish HCsCR effortlessly
# onto GitHub and Discord. It does the following:
#
# 1.  Checks that all required (CLI) tools are installed.
# 2.  Extracts the actual mod version from 'gradle.properties'.
# 3.  Guesses the version flavor based on the version string:
#     - "alpha", "beta", "rc", and "snapshot" versions
#       will become Pre-Release on GitHub.
#     - Other versions will become Release on GitHub.
# 4.  Locates and checks the JAR files in the 'build/libs' folder.
# 5.  Sources the authentication tokens from the environment.
#     - GitHub token is sourced from UPLOAD_GITHUB_TOKEN.
#     - Discord webhook URL is sourced from UPLOAD_DISCORD_WEBHOOK.
#     - Additional sourcing is done by executing 'dev/.env' file. It is
#       an optional Git-ignored shell script, you can paste tokens
#       as-is or do custom sourcing (like from a password manager).
# 6.  If tokens aren't found, errors and stops.
# 7.  Asks the user for the Markdown changelog in some $EDITOR. (vim/nano)
# 8.  Does some hackery to make changelogs on Discord appear the same
#     as they do on GitHub. (e.g., adds the issue/PR hyperlinks, "Full
#     Changelog" Git tag comparisons on GitHub hyperlinks and more)
# 9.  Shows the changelog and asks for the final confirmation.
# 10. Publishes to GitHub. (In multiple steps to support Immutable Releases)
#     - Creates a Draft release, attaches all metadata but files. (mutable)
#     - Attaches the file assets to the release.
#     - Publishes it, making it immutable.
# 11. Notifies via the webhook on Discord.
#
# This script is adapted from the GitHub:VidTu/Ksyxis repository.
#
# Required CLI tools:
#  cat curl grep jq mktemp sed sh tr
#
# Any POSIX shell should work, no bash-isms used (intentionally). The script
# should be system-agnostic, but was tested with MinGW (Windows) and Debian.

# Fail on error, fail on unbound variable, pipefail mode.
set -euo pipefail

# Begin.
echo 'NOTE: Uploading HCsCR...'

# Test the tools.
echo 'Checking tools...'
UPLOAD_TOOLS='cat curl grep jq mktemp sed tr'
for UPLOAD_TOOL in $UPLOAD_TOOLS; do
    command -v "${UPLOAD_TOOL}" >/dev/null || { echo "ERROR: Missing command '${UPLOAD_TOOL}'. All needed tools: ${UPLOAD_TOOLS}"; exit 1; }
done
command -v "${EDITOR:-vi}" >/dev/null || { echo "ERROR: Missing editor set via EDITOR: ${EDITOR:-vi}"; exit 1; }
echo 'Found all needed tools.'

# Source the version.
echo "Extracting the version from 'gradle.properties'..."
UPLOAD_VERSION=$(grep -F 'version=' '../gradle.properties' | sed 's/version=//g')
UPLOAD_VERSION_JSON=$(echo "${UPLOAD_VERSION}" | jq --raw-input --compact-output)
echo "NOTE: Version: ${UPLOAD_VERSION}"

# Create a display name.
UPLOAD_NAME="HCsCR ${UPLOAD_VERSION}"
UPLOAD_NAME_JSON=$(echo "${UPLOAD_NAME}" | jq --raw-input --compact-output)
echo "NOTE: Name: ${UPLOAD_VERSION}"

# Guess version type.
echo 'Guessing the version type...'
UPLOAD_VERSION_PRE='false'
UPLOAD_VERSION_TYPE='release'
echo "${UPLOAD_VERSION}" | grep -Eiq -- '-(beta|rc)' && UPLOAD_VERSION_TYPE='beta'
echo "${UPLOAD_VERSION}" | grep -Eiq -- '-(alpha|snapshot)' && UPLOAD_VERSION_TYPE='alpha'
[ "${UPLOAD_VERSION_TYPE}" != 'release' ] && UPLOAD_VERSION_PRE='true'
echo "NOTE: Version Pre-Release (GitHub): ${UPLOAD_VERSION_PRE}"
echo "NOTE: Version Type (Modrinth/CurseForge): ${UPLOAD_VERSION_TYPE}"

# Extract the versions into a temporary file.
echo 'Extracting the versions into a temporary file...'
UPLOAD_VERSIONS_TEMP=$(mktemp -t 'hcscr.upload-versions.XXXXXXX.txt')
grep -Evh '^#|^$' 'versions/versions_active.txt' 'versions/versions_legacy.txt' > "${UPLOAD_VERSIONS_TEMP}"
echo "Extracted the versions into: ${UPLOAD_VERSIONS_TEMP}"

# Find the JARs.
echo 'Checking all JAR files...'
UPLOAD_VERSIONS_IGNORED=$(grep -Evh '^#|^$' 'versions/ignored.txt')
UPLOAD_FILES=""
while read -r UPLOAD_MC; do
    for UPLOAD_TYPE in fabric forge neoforge; do
        UPLOAD_ID="${UPLOAD_MC}-${UPLOAD_TYPE}"
        # Check if ignored.
        if ! echo "${UPLOAD_VERSIONS_IGNORED}" | grep -Fxq "${UPLOAD_ID}"; then
            # Check if JAR exists.
            UPLOAD_FILENAME="HCsCR-${UPLOAD_VERSION}+${UPLOAD_ID}.jar"
            UPLOAD_FILE="../build/libs/${UPLOAD_FILENAME}"
            [ ! -f "${UPLOAD_FILE}" ] && echo "ERROR: Missing '${UPLOAD_FILENAME}' JAR file." && rm -- "${UPLOAD_VERSIONS_TEMP}" && exit 1

            # Add the JAR.
            UPLOAD_FILES="${UPLOAD_FILES}${UPLOAD_FILE}
"
        fi
    done
done < "${UPLOAD_VERSIONS_TEMP}"
rm -- "${UPLOAD_VERSIONS_TEMP}"
UPLOAD_FILES="${UPLOAD_FILES%?}"
UPLOAD_FILES=$(echo "${UPLOAD_FILES}" | sort -V)
echo 'Found all needed JAR files.'

# Source the '.env' file.
if [ -f '.env' ]; then
    echo "Sourcing '.env'..."
    . ./.env
    echo "Sourced '.env'."
else
    echo "Missing '.env', not sourced."
fi

# Verify the tokens.
echo 'Checking the tokens...'
[ -z "${UPLOAD_GITHUB_SKIP:-}" ] && [ -z "${UPLOAD_GITHUB_TOKEN:-}" ] && echo "ERROR: Missing UPLOAD_GITHUB_TOKEN. Use '.env' file in 'dev' or your shell's environment variables." && exit 1
[ -z "${UPLOAD_DISCORD_SKIP:-}" ] && [ -z "${UPLOAD_DISCORD_WEBHOOK:-}" ] && echo "ERROR: Missing UPLOAD_DISCORD_WEBHOOK. Use '.env' file in 'dev' or your shell's environment variables." && exit 1
echo 'All tokens found.'

# Create a temporary file for the changelog.
echo 'Preparing a changelog template...'
UPLOAD_CHANGELOG_FILE=$(mktemp -t hcscr.upload-changelog.XXXXXXX.md)
echo "Created a changelog template: ${UPLOAD_CHANGELOG_FILE}"

# Write a hint for the changelog.
echo 'Writing the changelog template...'
echo "What's new:

- [CHANGELOG]

**Full Changelog**: https://github.com/VidTu/HCsCR/compare/[PREV]...${UPLOAD_VERSION}" > "${UPLOAD_CHANGELOG_FILE}"
echo 'Written the changelog template.'

# Edit the changelog with an editor. (fallback to an unquittable one)
echo 'Opening the changelog file in the editor...'
"${EDITOR:-vi}" -- "${UPLOAD_CHANGELOG_FILE}"
echo 'Finished editing the changelog file.'

# Check if the changelog is not empty.
echo 'Checking the changelog...'
grep -Eq '\S' -- "${UPLOAD_CHANGELOG_FILE}" || { echo 'ERROR: Empty changelog.'&& rm -- "${UPLOAD_CHANGELOG_FILE}" && exit 1; }

# Read and format the changelog.
UPLOAD_CHANGELOG=$(cat -- "${UPLOAD_CHANGELOG_FILE}")
rm -- "${UPLOAD_CHANGELOG_FILE}"
UPLOAD_CHANGELOG_JSON=$(echo "${UPLOAD_CHANGELOG}" | jq --raw-input --slurp --compact-output)
UPLOAD_CHANGELOG_DISCORD=$(echo "${UPLOAD_CHANGELOG}" | sed -Ee 's/^\*\*Full Changelog\*\*: (https:\/\/github.com\/VidTu\/HCsCR\/compare\/(.*))$/**Full Changelog**: [\2](\1)/g' -e 's/(issue|PR): #([0-9]+)/\1: [#\2](https:\/\/github.com\/VidTu\/HCsCR\/issues\/\2)/g' | tr '\n' '\r' | sed 's/\r\r/\r/g' | tr '\r' '\n')
UPLOAD_CHANGELOG_DISCORD_JSON=$(echo "${UPLOAD_CHANGELOG_DISCORD}" | jq --raw-input --slurp --compact-output)

# Print the changelog.
echo '===== CHANGELOG START ====='
echo "${UPLOAD_CHANGELOG}"
echo '===== CHANGELOG END ====='

# Final confirmation.
echo 'Ready to upload. Press Enter to confirm, terminate (CTRL+C) to cancel.'
read -r _

# Skip GitHub, if desired.
if [ -z "${UPLOAD_GITHUB_SKIP:-}" ]; then
    # Create a GitHub release draft.
    echo 'Creating a GitHub release draft...'
    UPLOAD_GITHUB_DRAFT=$(curl --fail-with-body --max-time 30 --retry 3 --request POST --header 'Content-Type: application/json' --header "Authorization: Bearer ${UPLOAD_GITHUB_TOKEN}" --data-raw "{\"tag_name\":${UPLOAD_VERSION_JSON},\"name\":${UPLOAD_NAME_JSON},\"body\":${UPLOAD_CHANGELOG_JSON},\"draft\":true,\"prerelease\":${UPLOAD_VERSION_PRE}}" 'https://api.github.com/repos/VidTu/HCsCR/releases')
    echo 'Created a GitHub release draft.'

    # Extract the GitHub release ID.
    echo 'Extracting the GitHub release draft ID...'
    UPLOAD_GITHUB_ID=$(echo "${UPLOAD_GITHUB_DRAFT}" | jq --raw-output '.id')
    echo "Extracted the GitHub release draft ID: ${UPLOAD_GITHUB_ID}"

    # Upload the files to the GitHub release draft.
    echo 'Uploading files to the GitHub release draft...'
    echo "${UPLOAD_FILES}" | while read -r UPLOAD_FILE; do
        UPLOAD_FILENAME=$(basename -- "${UPLOAD_FILE}")
        echo "Uploading file '${UPLOAD_FILENAME}'..."
        curl --fail-with-body --max-time 30 --retry 3 --request POST --header 'Content-Type: application/java-archive' --header "Authorization: Bearer ${UPLOAD_GITHUB_TOKEN}" --url-query "name=${UPLOAD_FILENAME}" --data-binary "@${UPLOAD_FILE}" "https://uploads.github.com/repos/VidTu/HCsCR/releases/${UPLOAD_GITHUB_ID}/assets"
        echo 'Uploaded.'
    done
    echo 'Uploaded files to the GitHub release draft.'

    # Publish a GitHub release from the draft.
    echo 'Publishing a GitHub release from the draft...'
    curl --fail-with-body --max-time 30 --retry 3 --request PATCH --header 'Content-Type: application/json' --header "Authorization: Bearer ${UPLOAD_GITHUB_TOKEN}" --data-raw '{"draft":false}' "https://api.github.com/repos/VidTu/HCsCR/releases/${UPLOAD_GITHUB_ID}"
    echo 'Published a GitHub release from the draft.'
fi

# Skip Discord, if desired.
if [ -z "${UPLOAD_DISCORD_SKIP:-}" ]; then
    # Notify via a Discord webhook notification.
    echo 'Publishing a Discord webhook notification...'
    UPLOAD_DISCORD_TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:00.000Z")
    curl --fail-with-body --max-time 30 --retry 3 --request POST --header 'Content-Type: application/json' --data-raw "{\"embeds\":[{\"title\":${UPLOAD_NAME_JSON},\"description\":${UPLOAD_CHANGELOG_DISCORD_JSON},\"color\":16746496,\"fields\":[{\"name\":\"Download\",\"value\":\"<:github:1495153741412696216> GitHub: https://github.com/VidTu/HCsCR/releases\"}],\"author\":{\"name\":\"VidTu\",\"url\":\"https://github.com/VidTu\",\"icon_url\":\"https://cdn.discordapp.com/avatars/339357082602176513/f82f8e810b31903775ed304d07319b1f.png?size=2048\"},\"footer\":{\"text\":\"HCsCR: Remove your end crystals faster!\",\"icon_url\":\"https://cdn.discordapp.com/avatars/1496705557711683676/a0d3030419ce81c201ef4b74d6da5622.png?size=2048\"},\"timestamp\":\"${UPLOAD_DISCORD_TIMESTAMP}\"}],\"components\":[{\"type\":1,\"components\":[{\"type\":2,\"style\":5,\"url\":\"https://github.com/VidTu/HCsCR/releases\",\"label\":\"GitHub\",\"emoji\":{\"name\":\"github\",\"id\":1495153741412696216}}]}]}" "${UPLOAD_DISCORD_WEBHOOK}?with_components=true"
    echo "Published a Discord webhook notification. !!! DON'T FORGET TO CLICK 'PUBLISH' ON IT. !!!"
fi
